# 1. OPTIMISATIONS : COMPRESSION GZIP / DEFLATE (Minify)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# 2. OPTIMISATIONS : CACHE DU NAVIGATEUR (Browser Caching)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Images (Photos) - Cache maximum car elles changent rarement
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # Fichiers CSS / JS (Minify/Cache)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    Header unset ETag
    FileETag None
    <filesMatch "\.(ico|jpe?g|png|gif|swf|svg|webp|css|js)$">
        Header set Cache-Control "max-age=31536000, public"
    </filesMatch>
</IfModule>

# 3. ROOTING ET REWRITE RULES 
RewriteEngine On

# Si le fichier ou le dossier demandé n'existe pas physiquement
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# logique : /article/123-peu-importe = pages/frontoffice/detail_article.php?id=123
RewriteRule ^article/([0-9]+)(?:-.*)?$ pages/frontoffice/detail_article.php?id=$1 [L,QSA]
